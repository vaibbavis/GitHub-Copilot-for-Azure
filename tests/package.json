{
  "name": "azure-copilot-skills-tests",
  "version": "1.0.0",
  "description": "Test suite for Azure Copilot Skills",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:unit": "node scripts/run-tests.js unit",
    "test:integration": "node scripts/run-tests.js integration",
    "test:verbose": "node scripts/run-tests.js verbose",
    "test:ci": "node scripts/run-tests.js ci",
    "test:watch": "node scripts/run-tests.js watch",
    "test:skill": "node scripts/run-tests.js skill",
    "test:vally": "npx tsx ./run-vally-test.ts",
    "report": "npx tsx scripts/generate-test-reports.ts",
    "upload:token-usage": "npx tsx scripts/upload-token-usage.ts",
    "upload:tool-usage": "npx tsx scripts/upload-tool-usage.ts",
    "results": "node scripts/show-test-results.js",
    "update:mcp-tool-snapshot": "node scripts/update-mcp-tool-snapshot.js",
    "update:snapshots": "node scripts/update-snapshots.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "eval": "vally eval",
    "eval:lint": "vally lint plugin/skills/ --eval evals/ --strict"
  },
  "engines": {
    "node": "^22.14.0 || >=24"
  },
  "devDependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@eslint/js": "^10.0.0",
    "@github/copilot-sdk": "^1.0.5",
    "@microsoft/vally-cli": "^0.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.1",
    "gray-matter": "^4.0.3",
    "html-entities": "^2.6.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "simple-git": "^3.36.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.61.0"
  },
  "jest-junit": {
    "outputDirectory": "./reports",
    "outputName": "junit.xml",
    "ancestorSeparator": " › ",
    "uniqueOutputName": false,
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  }
}